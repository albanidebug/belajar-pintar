                    { q: "Cahaya bersifat gelombang dan partikel disebut...", o: ["Relativitas", "Dualitas", "Kuantitas", "Polaritas"], a: 1 },
                    { q: "Satuan frekuensi adalah...", o: ["Joule", "Hertz", "Watt", "Volt"], a: 1 },
                    { q: "Penemu teori relativitas adalah...", o: ["Newton", "Einstein", "Planck", "Bohr"], a: 1 },
                    { q: "Partikel penyusun inti atom adalah...", o: ["Proton & Elektron", "Proton & Neutron", "Neutron & Elektron", "Foton"], a: 1 },
                    { q: "Alat untuk mendeteksi radiasi nuklir adalah...", o: ["Termometer", "Barometer", "Pencacah Geiger", "Stetoskop"], a: 2 },
                    { q: "Foton adalah paket energi dari...", o: ["Listrik", "Cahaya", "Suara", "Panas"], a: 1 },
                    { q: "Warna cahaya dengan energi tertinggi adalah...", o: ["Merah", "Kuning", "Hijau", "Ungu/Violet"], a: 3 },
                    { q: "Kecepatan cahaya di ruang hampa sekitar...", o: ["300.000 km/s", "3.000 km/s", "30.000 km/s", "3.000.000 km/s"], a: 0 },
                    { q: "Model atom yang menyerupai tata surya dikemukakan oleh...", o: ["Thomson", "Rutherford", "Dalton", "Bohr"], a: 1 },
                    { q: "Prinsip ketidakpastian dikemukakan oleh...", o: ["Schrodinger", "Heisenberg", "Fermi", "Dirac"], a: 1 },
                    { q: "Suhu nol mutlak terjadi pada...", o: ["0 derajat Celsius", "0 derajat Fahrenheit", "0 Kelvin", "-100 derajat Celsius"], a: 2 }
                ],
                'bio': [
                    { q: "DNA berbentuk struktur yang disebut...", o: ["Lingkaran", "Heliks Ganda", "Lembaran", "Kubus"], a: 1 },
                    { q: "Siapa bapak genetika?", o: ["Darwin", "Mendel", "Lamarck", "Watson"], a: 1 },
                    { q: "Basa nitrogen yang berpasangan dengan Adenin di DNA adalah...", o: ["Guanin", "Sitosin", "Timin", "Urasil"], a: 2 },
                    { q: "Tempat terjadinya fotosintesis adalah...", o: ["Mitokondria", "Kloroplas", "Ribosom", "Lisosom"], a: 1 },
                    { q: "Jumlah kromosom pada sel sperma manusia adalah...", o: ["46", "23", "24", "22"], a: 1 },
                    { q: "Penyakit akibat mutasi genetik pada sel darah merah adalah...", o: ["Anemia", "Leukimia", "Sel Sabit (Sickle Cell)", "Hipertensi"], a: 2 },
                    { q: "CRISPR adalah teknologi untuk...", o: ["Melihat bakteri", "Mengedit gen", "Membuat vaksin", "Kloning domba"], a: 1 },
                    { q: "Proses pembelahan sel untuk pertumbuhan disebut...", o: ["Meiosis", "Mitosis", "Sintesis", "Osmosis"], a: 1 },
                    { q: "Organisme yang materi genetiknya dimodifikasi disebut...", o: ["UFO", "GMO", "DNA", "RNA"], a: 1 },
                    { q: "Hormon yang mengatur kadar gula darah adalah...", o: ["Adrenalin", "Tiroksin", "Insulin", "Estrogen"], a: 2 },
                    { q: "Bagian terkecil dari makhluk hidup adalah...", o: ["Jaringan", "Organ", "Sel", "Sistem"], a: 2 },
                    { q: "Urutan DNA yang mengodekan protein disebut...", o: ["Gen", "Alel", "Kromosom", "Inti"], a: 0 },
                    { q: "Virus membawa materi genetik berupa...", o: ["Hanya DNA", "Hanya RNA", "DNA atau RNA", "Protein saja"], a: 2 }
                ],
                'eko': [
                    { q: "Inflasi berarti nilai uang menjadi...", o: ["Naik", "Turun", "Tetap", "Hilang"], a: 1 },
                    { q: "Ekonomi makro mempelajari tentang...", o: ["Pasar tradisional", "Harga cabai", "Pengangguran nasional", "Laba toko"], a: 2 },
                    { q: "Pajak termasuk dalam kebijakan...", o: ["Moneter", "Fiskal", "Diskonto", "Pasar Terbuka"], a: 1 },
                    { q: "PDB adalah singkatan dari...", o: ["Produk Dalam Bangsa", "Produk Domestik Bruto", "Pendapatan Daerah Bersih", "Pasar Dalam Bursa"], a: 1 },
                    { q: "Bank Sentral Indonesia adalah...", o: ["BRI", "BNI", "Bank Indonesia", "BCA"], a: 2 },
                    { q: "Kelebihan nilai ekspor dibanding impor disebut...", o: ["Defisit", "Surplus", "Resesi", "Depresi"], a: 1 },
                    { q: "Upaya mengendalikan jumlah uang beredar disebut kebijakan...", o: ["Fiskal", "Moneter", "Sosial", "Politik"], a: 1 },
                    { q: "Bapak ekonomi modern adalah...", o: ["Adam Smith", "Karl Marx", "Keynes", "Malthus"], a: 0 },
                    { q: "Penurunan PDB selama dua kuartal berturut-turut disebut...", o: ["Inflasi", "Resesi", "Deflasi", "Stagnasi"], a: 1 },
                    { q: "Pasar dengan banyak penjual barang yang mirip disebut...", o: ["Monopoli", "Oligopoli", "Persaingan Sempurna", "Monopsoni"], a: 2 },
                    { q: "Alat tukar yang sah di suatu negara disebut...", o: ["Barter", "Emas", "Mata Uang", "Cek"], a: 2 },
                    { q: "Ilmu ekonomi muncul karena adanya...", o: ["Banyak uang", "Kelangkaan", "Pemerintah", "Pasar"], a: 1 }
                ]
            }
        };

        const app = {
            currentSubject: null,
            answers: [],

            init() {
                this.renderHome();
                this.renderSidebar();
            },

            showHome() {
                document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
                document.getElementById('view-home').classList.add('active');
                window.scrollTo(0,0);
            },

            showLibrary() {
                document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
                document.getElementById('view-library').classList.add('active');
                document.getElementById('lib-welcome').classList.remove('hidden');
                document.getElementById('article-area').classList.add('hidden');
                document.getElementById('quiz-area').classList.add('hidden');
                
                // Reset active sidebar
                document.querySelectorAll('#sidebar-nav button').forEach(b => b.classList.remove('nav-item-active'));
            },

            renderHome() {
                const grid = document.getElementById('home-grid');
                grid.innerHTML = appData.subjects.map(s => `
                    <div onclick="app.openSubject('${s.id}')" class="subject-card bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
                        <div class="text-5xl mb-6">${s.icon}</div>
                        <h4 class="text-2xl font-black text-slate-900 mb-2">${s.cat}</h4>
                        <p class="text-slate-500 font-medium">${s.desc}</p>
                    </div>
                `).join('');
            },

            renderSidebar() {
                const nav = document.getElementById('sidebar-nav');
                nav.innerHTML = appData.subjects.map(s => `
                    <button id="nav-${s.id}" onclick="app.loadArticle('${s.id}')" class="w-full flex items-center gap-4 p-4 rounded-2xl hover:bg-slate-50 transition-all group cursor-pointer">
                        <span class="text-2xl group-hover:scale-125 transition-transform">${s.icon}</span>
                        <div class="text-left">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-tighter">${s.cat}</p>
                            <p class="font-bold text-slate-700 leading-tight">${s.title.split(':')[0]}</p>
                        </div>
                    </button>
                `).join('');
            },

            openSubject(id) {
                this.showLibrary();
                this.loadArticle(id);
            },

            loadArticle(id) {
                this.currentSubject = id;
                const subject = appData.subjects.find(s => s.id === id);
                const article = appData.articles[id];

                document.getElementById('lib-welcome').classList.add('hidden');
                document.getElementById('article-area').classList.remove('hidden');
                document.getElementById('quiz-area').classList.add('hidden');

                document.getElementById('art-category').textContent = subject.cat;
                document.getElementById('art-title').textContent = subject.title;
                document.getElementById('art-desc').textContent = subject.desc;
                document.getElementById('art-body').innerHTML = article.body;

                // TOC
                const tocLinks = document.getElementById('toc-links');
                tocLinks.innerHTML = article.toc.map(t => `
                    <a href="#${t.id}" class="toc-link block py-2 px-3 text-sm font-bold text-slate-500 rounded-lg">
                        ${t.text}
                    </a>
                `).join('');

                // Sidebar Active State
                document.querySelectorAll('#sidebar-nav button').forEach(b => b.classList.remove('nav-item-active'));
                document.getElementById(`nav-${id}`).classList.add('nav-item-active');

                window.scrollTo(0,0);
            },

            startQuiz() {
                const questions = appData.quizzes[this.currentSubject];
                const subject = appData.subjects.find(s => s.id === this.currentSubject);
                this.answers = new Array(questions.length).fill(null);
                
                document.getElementById('article-area').classList.add('hidden');
                document.getElementById('quiz-area').classList.remove('hidden');
                document.getElementById('result-view').classList.add('hidden');
                document.getElementById('quiz-questions-list').classList.remove('hidden');
                document.getElementById('submit-quiz-btn').classList.remove('hidden');
                document.getElementById('quiz-modul-name').textContent = subject.cat;
                
                const list = document.getElementById('quiz-questions-list');
                list.innerHTML = questions.map((q, i) => `
                    <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm animate__animated animate__fadeInUp">
                        <div class="flex gap-4 mb-6">
                            <span class="w-8 h-8 rounded-lg bg-blue-600 text-white flex-shrink-0 flex items-center justify-center font-black text-sm">${i+1}</span>
                            <p class="text-xl font-bold text-slate-800">${q.q}</p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            ${q.o.map((opt, oi) => `
                                <button onclick="app.selectOption(${i}, ${oi})" id="q-${i}-o-${oi}" class="option-btn w-full text-left p-5 rounded-2xl border-2 border-slate-100 font-bold text-slate-600 flex items-center gap-4 cursor-pointer">
                                    <span class="w-6 h-6 rounded-md bg-slate-100 text-slate-400 flex items-center justify-center text-[10px]">${String.fromCharCode(65+oi)}</span>
                                    <span>${opt}</span>
                                </button>
                            `).join('')}
                        </div>
                    </div>
                `).join('');

                this.updateQuizMeta();
                window.scrollTo(0,0);
            },

            selectOption(qIdx, oIdx) {
                const questions = appData.quizzes[this.currentSubject];
                this.answers[qIdx] = oIdx;

                for(let i=0; i < questions[qIdx].o.length; i++) {
                    document.getElementById(`q-${qIdx}-o-${i}`).classList.remove('selected', 'bg-blue-50', 'border-blue-600', 'text-blue-600');
                }

                const selected = document.getElementById(`q-${qIdx}-o-${oIdx}`);
                selected.classList.add('selected', 'bg-blue-50', 'border-blue-600', 'text-blue-600');
                this.updateQuizMeta();
            },

            updateQuizMeta() {
                const answered = this.answers.filter(a => a !== null).length;
                const total = this.answers.length;
                document.getElementById('quiz-counter').textContent = `Soal Terjawab: ${answered} / ${total}`;
                
                const btn = document.getElementById('submit-quiz-btn');
                if(answered === total) {
                    btn.disabled = false;
                    document.getElementById('quiz-msg').textContent = "Sempurna! Semua soal sudah dijawab.";
                    document.getElementById('quiz-msg').classList.replace('text-slate-500', 'text-green-600');
                } else {
                    btn.disabled = true;
                    document.getElementById('quiz-msg').textContent = "Selesaikan semua soal untuk mengumpulkan.";
                    document.getElementById('quiz-msg').classList.replace('text-green-600', 'text-slate-500');
                }
            },

            submitQuiz() {
                const questions = appData.quizzes[this.currentSubject];
                let score = 0;
                this.answers.forEach((ans, i) => {
                    if(ans === questions[i].a) score++;
                    for(let j=0; j < questions[i].o.length; j++) {
                        const b = document.getElementById(`q-${i}-o-${j}`);
                        b.disabled = true;
                        if(j === questions[i].a) b.classList.add('bg-green-50', 'border-green-600', 'text-green-600');
                        else if(ans === j) b.classList.add('bg-red-50', 'border-red-600', 'text-red-600');
                    }
                });

                const finalScore = Math.round((score / questions.length) * 100);
                document.getElementById('final-score').textContent = finalScore;
                document.getElementById('result-view').classList.remove('hidden');
                document.getElementById('submit-quiz-btn').classList.add('hidden');
                document.getElementById('quiz-msg').classList.add('hidden');
                document.getElementById('study-progress').style.width = '100%';
                
                window.scrollTo(0, document.body.scrollHeight);
            },

            backToArticle() {
                this.loadArticle(this.currentSubject);
            }
        };

        window.onload = () => app.init();
    </script>
</body>
